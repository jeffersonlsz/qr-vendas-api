"""
Environment variables template.
Copy this file to .env and fill in your values.
"""

# Application
APP_NAME="Sistema de Captação de Leads"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# API
API_PREFIX=/api/v1

# Firestore Configuration
# For production: set FIRESTORE_PROJECT_ID and FIRESTORE_CREDENTIALS_PATH
# For development: set FIRESTORE_EMULATOR_HOST
FIRESTORE_PROJECT_ID=
FIRESTORE_CREDENTIALS_PATH=
FIRESTORE_EMULATOR_HOST=localhost:8080

# Firebase Auth (optional for MVP)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
